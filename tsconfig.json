{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "moduleResolution": "bundler",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",

    "allowJs": true,
    "jsx": "react-jsx",

    "types": ["node"],

    "noEmit": true
  }
}